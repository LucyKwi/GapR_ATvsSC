(caulobacterfasta.seq)-int(window_length/2)):\n","        start=i-int(window_length/2)\n","        end=i+int(window_length/2)\n","        sliding_array[0][i]=ATcontent_caulo(start, end)\n","    return sliding_array\n","\n","#make a 300bp sliding window across genome\n","sliding_300_caulo=sliding_window_caulo(300)\n","\n","#save\n","np.save('./data/sliding_300_caulo.npy', sliding_300_caulo)"]},{"cell_type":"code","source":["#Load data from GapR-3xFLAG RNA-seq (GSM2690554)\n","!wget \\\n","  -O \"./data/GSM2690554_GapR-3xFLAG_f.wig.gz\" \\\n","\"https://ftp.ncbi.nlm.nih.gov/geo/samples/GSM2690nnn/GSM2690554/suppl/GSM2690554%5FGapR%2D3xFLAG%5Ff%2Ewig%2Egz\"\n","\n","!gunzip -kf \"./data/GSM2690554_GapR-3xFLAG_f.wig.gz\"\n","\n","!wget \\\n","  -O \"./data/GSM2690554_GapR-3xFLAG_r.wig.gz\" \\\n","\"https://ftp.ncbi.nlm.nih.gov/geo/samples/GSM2690nnn/GSM2690554/suppl/GSM2690554%5FGapR%2D3xFLAG%5Fr%2Ewig%2Egz\"\n","\n","!gunzip -kf \"./data/GSM2690554_GapR-3xFLAG_r.wig.gz\"\n","\n","#Load data from WT grown in glucose 6h RNA-seq (GSM2690552)\n","!wget \\\n","  -O \"./data/GSM2690552_WT_glu_f.wig.gz\" \\\n","'https://ftp.ncbi.nlm.nih.gov/geo/samples/GSM2690nnn/GSM2690552/suppl/GSM2690552%5FWT%5Fglu%5Ff%2Ewig%2Egz'\n","\n","!gunzip -kf \"./data/GSM2690552_WT_glu_f.wig.gz\"\n","\n","!wget \\\n","  -O \"./data/GSM2690552_WT_glu_r.wig.gz\" \\\n","  \"https://ftp.ncbi.nlm.nih.gov/geo/samples/GSM2690nnn/GSM2690552/suppl/GSM2690552%5FWT%5Fglu%5Fr%2Ewig%2Egz\"\n","\n","!gunzip -kf \"./data/GSM2690552_WT_glu_r.wig.gz\"\n","\n","#Load data from GapR depletion in glucose 6h RNA-seq (GSM2690553)\n","\n","!wget \\\n","-O \"./data/GSM2690553_GapR_glu_f.wig.gz\" \\\n","\"https://ftp.ncbi.nlm.nih.gov/geo/samples/GSM2690nnn/GSM2690553/suppl/GSM2690553%5FGapR%5Fglu%5Ff%2Ewig%2Egz\"\n","\n","!gunzip -kf \"./data/GSM2690553_GapR_glu_f.wig.gz\"\n","\n","!wget \\\n","-O \"./data/GSM2690553_GapR_glu_r.wig.gz\" \\\n","\"https://ftp.ncbi.nlm.nih.gov/geo/samples/GSM2690nnn/GSM2690553/suppl/GSM26905