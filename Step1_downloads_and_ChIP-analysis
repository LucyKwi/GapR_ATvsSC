.drop(columns=['is_overlapping'])\n","        return overlapping_df, non_overlapping_df\n","    else:\n","        return num_overlaps, num_non_overlaps\n","\n","#run calculate_overlap_of_max_chip on 5% and 20%\n","rif_overlapping_groupB_5_max_df, rif_non_overlapping_groupB_5_max_df = calculate_overlap_of_max_chip(groupAB_5_df, rif_enriched_windows_5, 'max_chip_position', return_dataframe=True)\n","rif_overlapping_groupB_20_max_df, rif_non_overlapping_groupB_20_max_df = calculate_overlap_of_max_chip(groupAB_20_df, rif_enriched_windows_20, 'max_chip_position', return_dataframe=True)\n","\n","# Assign group B and group BOTH reflecting on if there is an overlap in rif\n","groupBOTH_5_df = rif_overlapping_groupB_5_max_df\n","groupB_5_df = rif_non_overlapping_groupB_5_max_df\n","\n","groupBOTH_20_df = rif_overlapping_groupB_20_max_df\n","groupB_20_df = rif_non_overlapping_groupB_20_max_df\n","\n"]},{"cell_type":"markdown","metadata":{"id":"KAqp1UjVX7rh"},"source":["# measure distance to TSS (start sites)\n"]},{"cell_type":"code","source":["def find_nearest_tss(position, tss_df):\n","    \"\"\"Finds the nearest TSS location, the distance to it, and its strand.\"\"\"\n","    tss_locations = tss_df['TSS location'].values\n","    tss_strands = tss_df['strand'].values\n","    distances = np.abs(tss_locations - position)\n","    nearest_tss_index = np.argmin(distances)\n","    nearest_tss_location = tss_locations[nearest_tss_index]\n","    min_distance = distances[nearest_tss_index]\n","    nearest_tss_strand = tss_strands[nearest_tss_index]\n","    return nearest_tss_location, min_distance, nearest_tss_strand"],"metadata":{"id":"qC0AO-xJr_L0"},"execution_count":null,"outputs":[]},{"cell_type":"code","execution_count":null,"metadata":{"id":"2YMRa2bdan2P"},"outputs":[],"source":["#measure the nearest tss information including location, orientation, and distance\n","rif_enriched_windows_5['nearest_tss_location'], rif_enriched_windows_5['distance_to_nearest_tss'], rif_enriched_win