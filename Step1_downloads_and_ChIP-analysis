ositive_strand_downstream_tss.empty:\n","        distances = positive_strand_downstream_tss['TSS location'] - peak_position\n","        idx = distances.idxmin() # This gives the index in the filtered DataFrame\n","        if distances[idx] < min_distance:\n","            min_distance = distances[idx]\n","            closest_tss_location = positive_strand_downstream_tss.loc[idx, 'TSS location']\n","            closest_tss_strand = positive_strand_downstream_tss.loc[idx, 'strand']\n","\n","    # Check negative strand TSSs\n","    if not negative_strand_downstream_tss.empty:\n","        distances = peak_position - negative_strand_downstream_tss['TSS location']\n","        idx = distances.idxmin() # This gives the index in the filtered DataFrame\n","        if distances[idx] < min_distance: # Compare to current min_distance\n","            min_distance = distances[idx]\n","            closest_tss_location = negative_strand_downstream_tss.loc[idx, 'TSS location']\n","            closest_tss_strand = negative_strand_downstream_tss.loc[idx, 'strand']\n","\n","    return closest_tss_location, closest_tss_strand, min_distance"],"metadata":{"id":"g1It9YuqwjDn"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["groupA_5_df[['closest_downstream_tss', 'closest_downstream_tss_strand', 'distance_to_closest_downstream_tss']] = groupA_5_df['max_chip_position'].apply(lambda x: downstream_TSS(x, all_tss)).apply(pd.Series)\n","groupA_20_df[['closest_downstream_tss', 'closest_downstream_tss_strand', 'distance_to_closest_downstream_tss']] = groupA_20_df['max_chip_position'].apply(lambda x: downstream_TSS(x, all_tss)).apply(pd.Series)\n","groupB_5_df[['closest_downstream_tss', 'closest_downstream_tss_strand', 'distance_to_closest_downstream_tss']] = groupB_5_df['max_chip_position'].apply(lambda x: downstream_TSS(x, all_tss)).apply(pd.Series)\n","groupB_20_df[['closest_downstream_tss', 'closest_downstream_tss_strand', 'distance_to_closest_downstream_tss']] = groupB_20_df[