me({\n","    'position': RDepglu_RNAfor_df['position'],\n","    'value': RDepglu_RNAfor_df['value'].abs() + RDepglu_RNArev_df['value'].abs() + 0.1\n","})"]},{"cell_type":"code","source":["#@title make log2fold change array\n","#for quicker processing adding a small pseudocount to avoid 0s\n","\n","def build_log2foldchange_dataframes(WT_RNAfor_dataframe,\n","                                    WT_RNArev_dataframe,\n","                                    RDep_RNAfor_dataframe,\n","                                    RDep_RNArev_dataframe,\n","                                    pseudocount=0.01):\n","    \"\"\"\n","    Builds two genome-wide log2 fold change dataframes:\n","      1) log2foldchange_forward: position + log_2_fold_change_for\n","      2) log2foldchange_reverse: position + log_2_fold_change_rev\n","\n","    Assumes each RNA dataframe has exactly:\n","      - 'position'\n","      - 'value'\n","\n","    This function will raise an error if WT and RDep do not have matching positions.\n","    \"\"\"\n","\n","    # Forward strand log2FC\n","    forward_merged_data = pd.merge(\n","        WT_RNAfor_dataframe,\n","        RDep_RNAfor_dataframe,\n","        on='position',\n","        how='inner',\n","        suffixes=('_WT', '_RDep')\n","    )\n","\n","    if len(forward_merged_data) != len(WT_RNAfor_dataframe) or len(forward_merged_data) != len(RDep_RNAfor_dataframe):\n","        raise ValueError(\n","            \"Forward strand WT and RDep RNA-seq tracks do not have matching positions. \"\n","            \"Please regenerate or re-check the input RNA-seq dataframes.\"\n","        )\n","\n","    forward_merged_data['log_2_fold_change_for'] = np.log2(\n","        (forward_merged_data['value_RDep'] + pseudocount) /\n","        (forward_merged_data['value_WT'] + pseudocount)\n","    )\n","\n","    log2foldchange_forward = forward_merged_data[\n","        ['position', 'log_2_fold_change_for']\n","    ].sort_values('position').reset_index(drop=True)\n","\n","\n","    # Reverse strand log2FC dataset\n","    reverse_merged_data = pd.merge(\n","        WT_RNArev_dataframe,\n","        RDep_RNArev_dataframe,\n","        on='position',\n","        how='inner',\n","        suffixes=('_WT', '_RDep')\n","    )\n","\n","    if len(reverse_merged_data) != len(WT_RNArev_dataframe) or len(reverse_merged_data) != len(RDep_RNArev_dataframe):\n","        raise ValueError(\n","            \"Reverse strand WT and RDep RNA-seq tracks do not have matching positions. \"\n","            \"Please regenerate or re-check the input RNA-seq dataframes.\"\n","        )\n","\n","    reverse_merged_data['log_2_fold_change_rev'] = np.log2(\n","        (reverse_merged_data['value_RDep'] + pseudocount) /\n","        (reverse_merged_data['value_WT'] + pseudocount)\n","    )\n","\n","    log2foldchange_reverse = reverse_merged_data[\n","        ['position', 'log_2_fold_change_rev']\n","    ].sort_values('position').reset_index(drop=True)\n","\n","    return log2foldchange_forward, log2foldchange_reverse\n","\n","\n","log2foldchange_forward, log2foldchange_reverse = build_log2foldchange_dataframes(\n","    WT_RNAfor_dataframe=WTglu_RNAfor_df,\n","    WT_RNArev_dataframe=WTglu_RNArev_df,\n","    RDep_RNAfor_dataframe=RDepglu_RNAfor_df,\n","    RDep_RNArev_dataframe=RDepglu_RNArev_df,\n","    pseudocount=0.01\n",")"],"metadata":{"id":"bp8B82I3yDGa"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["The next couple functions are all made to build a large pandas dataframe with all relevant information. It will ID the upstream transcription start site, the downstream txn start site, which one is closer, and the log2fold change in the strand conscious 500bp range at all these positions"],"metadata":{"id":"s5wybgIY7I7w"}},{"cell_type":"code","execution_count":null,"metadata":{"id":"7I9vI9J6ATcD"},"outputs":[],"source":["#function used to ID upstream TSS so this is strand-conscious\n","def upstream_TSS(peak_position, tss_df):\n","\n","    # Filter for positive strand TSSs : TSS location < peak_position and strand is '+')\n","    positive_strand_upstream_tss = tss_df[\n","        (tss_df['TSS location'] < peak_position) & (tss_df['strand'] == '+')\n","    ]\n","\n","    # Filter for negative strand TSSs: TSS location > peak_position and strand is '-')\n","    negative_strand_upstream_tss = tss_df[\n","        (tss_df['TSS location'] > peak_position) & (tss_df['strand'] == '-')\n","    ]\n","\n","    closest_tss_location = np.nan\n","    closest_tss_strand = np.nan\n","    min_distance = np.inf\n","\n","    # Check positive strand TSSs\n","    if not positive_strand_upstream_tss.empty:\n","        distances = peak_position - positive_strand_upstream_tss['TSS location']\n","        idx = distances.idxmin() # This gives the index in the filtered DataFrame\n","        if distances[idx] < min_distance:\n","            min_distance = distances[idx]\n","            closest_tss_location = positive_strand_upstream_tss.loc[idx, 'TSS location']\n","            closest_tss_strand = positive_strand_upstream_tss.loc[idx, 'strand']\n","\n","    # Check negative strand TSSs\n","    if not negative_strand_upstream_tss.empty:\n","        distances = negative_strand_upstream_tss['TSS location'] - peak_position\n","        idx = distances.idxmin() # This gives the index in the filtered DataFrame\n","        if distances[idx] < min_distance: # Compare to current min_distance\n","            min_distance = distances[idx]\n","            closest_tss_location = negative_strand_upstream_tss.loc[idx, 'TSS location']\n","            closest_tss_strand = negative_strand_upstream_tss.loc[idx, 'strand']\n","\n","    return closest_tss_location, closest_tss_strand, min_distance\n","\n","\n","\n","#run on all dfs\n","groupA_5_df[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = groupA_5_df['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","groupA_20_df[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = groupA_20_df['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","groupB_5_df[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = groupB_5_df['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","groupB_20_df[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = groupB_20_df['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","groupBOTH_5_df[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = groupBOTH_5_df['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","groupBOTH_20_df[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = groupBOTH_20_df['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","\n","rif_enriched_windows_5[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = rif_enriched_windows_5['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","rif_enriched_windows_20[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = rif_enriched_windows_20['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","wt_enriched_windows_5[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = wt_enriched_windows_5['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","wt_enriched_windows_20[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = wt_enriched_windows_20['max_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","wt_nochip_windows_5[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = wt_nochip_windows_5['min_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","wt_nochip_windows_20[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = wt_nochip_windows_20['min_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","rif_nochip_windows_5[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = rif_nochip_windows_5['min_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n","rif_nochip_windows_20[['closest_upstream_tss', 'closest_upstream_tss_strand', 'distance_to_closest_upstream_tss']] = rif_nochip_windows_20['min_chip_position'].apply(lambda x: upstream_TSS(x, all_tss)).apply(pd.Series)\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"OUI8Xu7vATLI"},"outputs":[],"source":["def find_max_txn_change_in_window(tss_location,\n","                                  tss_strand,\n","                                  log2foldchange_forward,\n","                                  log2foldchange_reverse,\n","                                  window_size=500):\n","    \"\"\"\n","    Finds the position and signed value of the largest log2 fold change (by magnitude)\n","    within a window downstream of a given TSS, considering the TSS strand.\n","\n","    Also returns the average and median signed log2 fold change across the downstream window.\n","\n","    The input dataframes should contain:\n","      - 'position'\n","      - log2foldchange_forward: 'log_2_fold_change_for'\n","      - log2foldchange_reverse: 'log_2_fold_change_rev'\n","    \"\"\"\n","\n","    # Initialize results\n","    max_change_position = np.nan\n","    max_change_value = np.nan\n","    wt_value_at_max_change = np.nan\n","\n","    avg_change_value = np.nan\n","    median_change_value = np.nan\n","\n","    if tss_strand == '+':\n","        # For positive strand, downstream is to the right (higher genomic positions)\n","        downstream_window_data = log2foldchange_forward[\n","            (log2foldchange_forward['position'] >= tss_location) &\n","            (log2foldchange_forward['position'] <= (tss_location + window_size))\n","        ]\n","\n","        if not downstream_window_data.empty:\n","            avg_change_value = downstream_window_data['log_2_fold_change_for'].mean()\n","            median_change_value = downstream_window_data['log_2_fold_change_for'].median()\n","\n","            downstream_window_data = downstream_window_data.copy()\n","            downstream_window_data['log2_fold_change_magnitude'] = np.abs(\n","                downstream_window_data['log_2_fold_change_for']\n","            )\n","\n","            row_with_largest_log2_fold_change = downstream_window_data.loc[\n","                downstream_window_data['log2_fold_change_magnitude'].idxmax()\n","            ]\n","\n","            max_change_position = row_with_largest_log2_fold_change['position']\n","            max_change_value = row_with_largest_log2_fold_change['log_2_fold_change_for']\n","\n","    elif tss_strand == '-':\n","        # For negative strand, downstream is to the left (lower genomic positions)\n","        downstream_window_data = log2foldchange_reverse[\n","            (log2foldchange_reverse['position'] >= (tss_location - window_size)) &\n","            (log2foldchange_reverse['position'] <= tss_location)\n","        ]\n","\n","        if not downstream_window_data.empty:\n","            avg_change_value = downstream_window_data['log_2_fold_change_rev'].mean()\n","            median_change_value = downstream_window_data['log_2_fold_change_rev'].median()\n","\n","            downstream_window_data = downstream_window_data.copy()\n","            downstream_window_data['log2_fold_change_magnitude'] = np.abs(\n","                downstream_window_data['log_2_fold_change_rev']\n","            )\n","\n","            row_with_largest_log2_fold_change = downstream_window_data.loc[\n","                downstream_window_data['log2_fold_change_magnitude'].idxmax()\n","            ]\n","\n","            max_change_position = row_with_largest_log2_fold_change['position']\n","            max_change_value = row_with_largest_log2_fold_change['log_2_fold_change_rev']\n","\n","    return max_change_position, max_change_value, avg_change_value, median_change_value\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"8cFOXbXvDv4K"},"outputs":[],"source":["# Calculate max transcriptional change for Group A, B, and BOTH\n","groupA_5_df['max_txn_change_500bp_upstream_tss_position'], groupA_5_df['max_txn_change_500bp_upstream_tss_value'], groupA_5_df['avg_txn_change_500bp_upstream_tss_value'], groupA_5_df['median_txn_change_500bp_upstream_tss_value'] = zip(*groupA_5_df.apply(lambda row: find_max_txn_change_in_window(row['closest_upstream_tss'], row['closest_upstream_tss_strand'], log2foldchange_forward, log2foldchange_reverse, window_size=500), axis=1))\n","groupB_5_df['max_txn_change_500bp_upstream_tss_position'], groupB_5_df['max_txn_change_500bp_upstream_tss_value'], groupB_5_df['avg_txn_change_500bp_upstream_tss_value'], groupB_5_df['median_txn_change_500bp_upstream_tss_value'] = zip(*groupB_5_df.apply(lambda row: find_max_txn_change_in_window(row['closest_upstream_tss'], row['closest_upstream_tss_strand'], log2foldchange_forward, log2foldchange_reverse, window_size=500), axis=1))\n","wt_enriched_windows_5['max_txn_change_500bp_upstream_tss_position'], wt_enriched_windows_5['max_txn_change_500bp_upstream_tss_value'], wt_enriched_windows_5['avg_txn_change_500bp_upstream_tss_value'], wt_enriched_windows_5['median_txn_change_500bp_upstream_tss_value'] = zip(*wt_enriched_windows_5.apply(lambda row: find_max_txn_change_in_window(row['closest_upstream_tss'], row['closest_upstream_tss_strand'], log2foldchange_forward, log2foldchange_reverse, window_size=500), axis=1))\n","wt_nochip_windows_5['max_txn_change_500bp_upstream_tss_positi