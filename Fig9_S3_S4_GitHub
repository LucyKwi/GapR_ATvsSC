ge value\n","    from the closest TSS (upstream or downstream), based on which TSS is closer\n","    to the 'max_chip_position'.\n","\n","    'closest_tss_direction' will indicate whether the closest TSS is 'upstream'\n","    or 'downstream'.\n","\n","    Args:\n","        df (pd.DataFrame): The input DataFrame containing the necessary columns.\n","\n","    Returns:\n","        pd.DataFrame: The DataFrame with the new columns added.\n","    \"\"\"\n","\n","    # Determine which TSS is closer and assign values accordingly\n","    df['closest_tss_direction'] = np.where(\n","        df['distance_to_closest_upstream_tss'] < df['distance_to_closest_downstream_tss'],\n","        'upstream',\n","        'downstream'\n","    )\n","\n","    df['closest_tss_position'] = np.where(\n","        df['distance_to_closest_upstream_tss'] < df['distance_to_closest_downstream_tss'],\n","        df['max_txn_change_500bp_upstream_tss_position'],\n","        df['max_txn_change_500bp_downstream_tss_position']\n","    )\n","\n","    # Confirmation: the \"max log2 fold change\" columns are:\n","    #   - upstream:   'max_txn_change_500bp_upstream_tss_value'\n","    #   - downstream: 'max_txn_change_500bp_downstream_tss_value'\n","    df['max_change_at_nearest_tss'] = np.where(\n","        df['distance_to_closest_upstream_tss'] < df['distance_to_closest_downstream_tss'],\n","        df['max_txn_change_500bp_upstream_tss_value'],\n","        df['max_txn_change_500bp_downstream_tss_value']\n","    )\n","\n","    return df\n"],"metadata":{"id":"_oMn5ufx5ECa","executionInfo":{"status":"ok","timestamp":1775579990392,"user_tz":420,"elapsed":3,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"execution_count":54,"outputs":[]},{"cell_type":"code","source":["# Apply the function to the 5% dataframes\n","groupA_5_df = add_nearest_tss_max_change_info(groupA_5_df)\n","groupB_5_df = add_nearest_tss_max_change_info(groupB_5_df.copy())\n","groupBOTH_5_df = add_nearest_ts