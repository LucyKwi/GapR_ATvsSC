e any additional time one TSS is called by multipule peaks."],"metadata":{"id":"NByXXy4U9cKB"}},{"cell_type":"code","source":["def find_common_tss(df_A, df_B, df_name, tss_column='nearest_tss_location'):\n","\n","    df_name = df_name\n","    tss_A = set(df_A[tss_column])\n","    tss_B = set(df_B[tss_column])\n","\n","    # Find the intersection (common TSS locations)\n","    common_tss = tss_A.intersection(tss_B)\n","\n","    # Filter both DataFrames to include only rows with common TSS locations\n","    df_A_common = df_A[df_A[tss_column].isin(common_tss)]\n","    df_B_common = df_B[df_B[tss_column].isin(common_tss)]\n","\n","    # Concatenate the filtered DataFrames into tss_in_AB\n","    tss_in_AB = pd.concat([df_A_common, df_B_common], ignore_index=True)\n","\n","    # calculate percent of df that was removed\n","    tssA_percent = (len(df_A_common)) / len(df_A) * 100\n","    tssB_percent = (len(df_B_common)) / len(df_B) * 100\n","\n","    print(f\"{len(tss_in_AB)} common TSS locations found in {df_name}. ({tssA_percent}% of A) and ({tssB_percent}% of B) \")\n","    return tss_in_AB\n"],"metadata":{"id":"01jZRSOFS1Y6","executionInfo":{"status":"ok","timestamp":1775579990743,"user_tz":420,"elapsed":2,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"execution_count":58,"outputs":[]},{"cell_type":"code","source":["# use find_common_tss to remove duplicates\n","tss_in_AB_top5_perc = find_common_tss(nearest_tss_top5_A_perc, nearest_tss_top5_B_perc, 'top5% AB', 'closest_tss_position')\n","tss_in_AB_top20_perc = find_common_tss(nearest_tss_top20_A_perc, nearest_tss_top20_B_perc, 'top20% AB', 'closest_tss_position')\n","\n","tss_in_wt5_top5_perc = find_common_tss(nearest_tss_wt_5_df, nearest_tss_wt_nochip_5_df, 'top5% wt', 'closest_tss_position')\n","tss_in_wt20_top20_perc = find_common_tss(nearest_tss_wt_20_df, nearest_tss_wt_nochip_20_df, 'top20% wt', 'closest_tss_position')\n","tss_in_rif5_top5_perc = find_common_tss(nearest_tss