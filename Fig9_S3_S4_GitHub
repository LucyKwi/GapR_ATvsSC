tor, int):\n","            col_name = df.columns[selector]\n","        else:\n","            col_name = selector\n","            if col_name not in df.columns:\n","                raise KeyError(f\"Column {col_name!r} not found.\")\n","        s = pd.to_numeric(df[col_name], errors=\"coerce\").dropna()\n","        if s.empty:\n","            raise ValueError(f\"Column {col_name!r} has no numeric values after coercion.\")\n","        return s, col_name\n"]},{"cell_type":"markdown","metadata":{"id":"yeIozocQC-nR"},"source":["Since I am measuring a window, there isnt a way to \"have the same TSS called twice\" and the inherent grouping of peaks means there will be no overlap. So here there are no remove duplicates or if the same peak is called as both AT- and +SC-dependent. We will however, filter for distance and chpose peaks where the GapR peak is near the transcription END site (depicted in Figure 9F)"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"NcxfjDI_FMCi"},"outputs":[],"source":["def filter_rows_by_tss_distance(df, distance_threshold):\n","    \"\"\"\n","same function from 9E but it is modified to look at the terminator column\n","    \"\"\"\n","\n","    # Decide which chip position column to use\n","    if 'max_chip_position' in df.columns:\n","        chip_position_column = 'max_chip_position'\n","    elif 'min_chip_position' in df.columns:\n","        chip_position_column = 'min_chip_position'\n","    else:\n","        raise ValueError(\n","            \"DataFrame must contain either 'max_chip_position' or 'min_chip_position'.\"\n","        )\n","\n","    # Calculate distance between closest TES and chosen chip position\n","    df['distance_between_chip_and_closest_tes'] = (\n","        df[chip_position_column] - df['nearest_tsstop_location']\n","    ).abs()\n","\n","    # Keep only rows within the distance threshold\n","    filtered_df = df[\n","        df['distance_between_chip_and_closest_tes'] <= distance_threshold\n","    ].copy()\n","\n","    return filtered_df\n","\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"tYgC7w56FMCi"},"outputs":[],"source":["#same 500bp filter\n","elongation_top5_A_perc = filter_rows_by_tss_distance(elongation_top5_A_perc, 500)\n","elongation_top5_B_perc = filter_rows_by_tss_distance(elongation_top5_B_perc, 500)\n","elongation_top5_BOTH_perc = filter_rows_by_tss_distance(elongation_top5_BOTH_perc, 500)\n","elongation_top20_A_perc = filter_rows_by_tss_distance(elongation_top20_A_perc, 500)\n","elongation_top20_B_perc = filter_rows_by_tss_distance(elongation_top20_B_perc, 500)\n","elongation_top20_BOTH_perc = filter_rows_by_tss_distance(elongation_top20_BOTH_perc, 500)\n","\n","elongation_wt_5_df = filter_rows_by_tss_distance(elongation_wt_5_df, 500)\n","elongation_wt_20_df = filter_rows_by_tss_distance(elongation_wt_20_df, 500)\n","elongation_rif_5_df = filter_rows_by_tss_distance(elongation_rif_5_df, 500)\n","elongation_rif_20_df = filter_rows_by_tss_distance(elongation_rif_20_df, 500)\n","\n","elongation_wt_nochip_5_df = filter_rows_by_tss_distance(elongation_wt_nochip_5_df, 500)\n","elongation_wt_nochip_20_df = filter_rows_by_tss_distance(elongation_wt_nochip_20_df, 500)\n","elongation_rif_nochip_5_df = filter_rows_by_tss_distance(elongation_rif_nochip_5_df, 500)\n","elongation_rif_nochip_20_df = filter_rows_by_tss_distance(elongation_rif_nochip_20_df, 500)"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"elapsed":2169,"status":"ok","timestamp":1783354068020,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"},"user_tz":420},"id":"jEYtndPooUqh","outputId":"f9aad287-292f-4187-f28b-019cb9411764"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["#@title nearest TSS remove long range chip sites\n","# Define the groups_vs_WT_nochip dictionary to ensure it's available\n","# These lambda functions refer to the dataframes loaded/modified in previous cells\n","\n","groups_vs_WT_nochip = {\n","    \"top5%AB\":  {\"Group B\": lambda: elongation_top5_B_perc,  \"Group A\": lambda: elongation_top5_A_perc},\n","    \"top20AB%\": {\"Group B\": lambda: elongation_top20_B_perc, \"Group A\": lambda: elongation_top20_A_perc},\n","    \"top5% wt\":  {\"wt ChIP\": lambda: elongation_wt_5_df,  \"WT nochip\": lambda: elongation_wt_nochip_5_df},\n","    \"top20% wt\": {\"wt ChIP\": lambda: elongation_rif_5_df, \"WT nochip\": lambda: elongation_wt_nochip_20_df},\n","    'top5% rif':  {\"rif ChIP\": lambda: elongation_rif_5_df,  \"rif nochip\": lambda: elongation_rif_nochip_5_df},\n","    'top20% rif': {\"rif ChIP\": lambda: elongation_rif_20_df, \"rif nochip\": lambda: elongation_rif_nochip_20_df},\n","\n","    }\n","\n","\n","#moved columns in previous matrix for easier plotting here\n","COLUMN_TO_PLOT = 2 # from moving columns around earlier\n","NUM_BINS = np.arange(-5,5,0.122) #BINS\n","NUM_BINS[0] = -10\n","NUM_BINS[-1] = 10\n","\n","from scipy.stats import mannwhitneyu # Import for MW test\n","\n","sns.set(style=\"white\")\n","\n","for group_key, group_data in groups_vs_WT_nochip.items():\n","    # Determine plot_labels and colors dynamically based on group_key\n","    current_plot_labels = []\n","    current_palette = []\n","\n","    if 'A' in group_key:\n","        current_plot_labels = [\"Group A\", \"Group B\"]\n","        current_palette = ['darkorange', 'green']\n","    elif 'wt' in group_key:\n","        current_plot_labels = [\"wt ChIP\", \"WT nochip\"]\n","        current_palette = ['purple', 'gray']\n","    elif 'rif' in group_key:\n","        current_plot_labels = [\"rif ChIP\", \"rif nochip\"]\n","        current_palette = ['green', 'gray']\n","    else:\n","        print(f\"Skipping {group_key}: unrecognized group type.\")\n","        continue\n","\n","    color_map = dict(zip(current_plot_labels, current_palette))\n","\n","    # Determine the x-axis label from the column name\n","    xlabel_text = str(COLUMN_TO_PLOT)\n","    first_df_found = False\n","    for lbl in current_plot_labels:\n","        if lbl in group_data:\n","            try:\n","                # Use a dummy call to resolve_series to get the column name\n","                s_temp, resolved_col_name = resolve_series(group_data[lbl](), COLUMN_TO_PLOT)\n","                xlabel_text = resolved_col_name\n","                first_df_found = True\n","                break\n","            except Exception:\n","                pass\n","    if not first_df_found:\n","        print(f\"Could not determine x-axis label for {group_key}. Using default '{xlabel_text}'.\")\n","\n","    fig, ax = plt.subplots(nrows=1, ncols=1, figsize=(10, 5)) # Single subplot per comparison\n","    fig.suptitle(f\"{group_key.replace('A%', ' A').replace('B%', ' B')} vs WT nochip Distributions ({xlabel_text})\", y=0.99, fontsize=16)\n","\n","    # Recompute global limits for the current comparison\n","    all_vals_current_group = []\n","    for lbl in current_plot_labels:\n","        if lbl in group_data:\n","            try:\n","                s, _ = resolve_series(group_data[lbl](), COLUMN_TO_PLOT)\n","                if len(s): all_vals_current_group.append(s.values)\n","            except Exception:\n","                pass\n","\n","    if not all_vals_current_group:\n","        print(f\"No numeric data found for {group_key} at selector {COLUMN_TO_PLOT!r}. Skipping plot.\")\n","        plt.close(fig) # Close empty figure\n","        continue\n","\n","    global_min = float(np.min([v.min() for v in all_vals_current_group]))\n","    global_max = float(np.max([v.max() for v in all_vals_current_group]))\n","\n","    panel_df_list = []\n","    data_for_mw = [] # To store data for MW test\n","\n","    for label in current_plot_labels:\n","        if label in group_data:\n","            try:\n","                df = group_data[label]()\n","                s, col_name = resolve_series(df, COLUMN_TO_PLOT)\n","                panel_df_list.append(pd.DataFrame({\"value\": s.values, \"Group\": label, \"Percentile\": group_key}))\n","                data_for_mw.append(s.values) # Collect data for MW test\n","            except (NameError, KeyError, IndexError, ValueError):\n","                continue\n","        else:\n","            pass\n","\n","    if not panel_df_list:\n","        ax.set_visible(False)\n","        plt.close(fig)\n","        continue\n","\n","    panel_df = pd.concat(panel_df_list, ignore_index=True)\n","\n","    # Perform MW test if two data series are available\n","    if len(data_for_mw) == 2:\n","        try:\n","            stat, p_value = mannwhitneyu(data_for_mw[0], data_for_mw[1])\n","            # Annotate plot with p-value\n","            ax.text(0.95, 0.95, f'MW p-value: {p_value:.3e}',\n","                    verticalalignment='top', horizontalalignment='right',\n","                    transform=ax.transAxes, color='black', fontsize=12)\n","        except ValueError as e:\n","            print(f\"Could not perform MW test for {group_key}: {e}\")\n","\n","    # Filled bars with black outline; legend per subplot\n","    sns.histplot(\n","        data=panel_df,\n","        x=\"value\",\n","        hue=\"Group\",\n","        hue_order=current_plot_labels,\n","        bin