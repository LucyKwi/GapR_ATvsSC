:420,"elapsed":798,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"outputs":[],"source":["# Function to find the position of the maximum value within a window\n","def get_max_chip_position(row, chip_data):\n","    start = int(row['start'])\n","    end = int(row['end'])\n","    window_data = chip_data[start:end+1]\n","    max_index_in_window = np.argmax(window_data)\n","\n","    return start + max_index_in_window\n","\n","\n","# Function to find the position of the minimum value within a window\n","def get_min_chip_position(row, chip_data):\n","    start = int(row['start'])\n","    end = int(row['end'])\n","    window_data = chip_data[start:end+1]\n","    min_index_in_window = np.argmin(window_data)\n","\n","    return start + min_index_in_window\n","\n","#find max ChIP of GapR enriched windows and min chip of GapR de-enriched windows\n","rif_enriched_windows_5['max_chip_position'] = rif_enriched_windows_5.apply(lambda row: get_max_chip_position(row, gapR_rif_norm), axis=1)\n","rif_nochip_windows_5['min_chip_position'] = rif_nochip_windows_5.apply(lambda row: get_min_chip_position(row, gapR_rif_norm), axis=1)\n","wt_enriched_windows_5['max_chip_position'] = wt_enriched_windows_5.apply(lambda row: get_max_chip_position(row, gapR_wt_norm), axis=1)\n","wt_nochip_windows_5['min_chip_position'] = wt_nochip_windows_5.apply(lambda row: get_min_chip_position(row, gapR_wt_norm), axis=1)\n","\n","rif_enriched_windows_20['max_chip_position'] = rif_enriched_windows_20.apply(lambda row: get_max_chip_position(row, gapR_rif_norm), axis=1)\n","rif_nochip_windows_20['min_chip_position'] = rif_nochip_windows_20.apply(lambda row: get_min_chip_position(row, gapR_rif_norm), axis=1)\n","wt_enriched_windows_20['max_chip_position'] = wt_enriched_windows_20.apply(lambda row: get_max_chip_position(row, gapR_wt_norm), axis=1)\n","wt_nochip_windows_20['min_chip_position'] = wt_nochip_windows_20.apply(lambda row: get_min_chip_position(row, gapR_wt_norm), axis=1)\n","\n","\n"]},{"cell_type":"code","execution_count":17,"metadata":{"id":"Iy2EICCbNA33","executionInfo":{"status":"ok","timestamp":1775579377169,"user_tz":420,"elapsed":75,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"outputs":[],"source":["def get_chip_at_position(row, chip_data):\n","    position = int(row['max_chip_position'])\n","    chip = chip_data[position]\n","    return chip\n","\n","#get max chIP signal position in window for all datasets\n","wt_enriched_windows_5['max_wt_chip_in_window'] = wt_enriched_windows_5.apply(lambda row: gapR_wt_norm.loc[int(row['max_chip_position'])], axis=1)\n","rif_enriched_windows_5['max_rif_chip_in_window'] = rif_enriched_windows_5.apply(lambda row: gapR_rif_norm.loc[int(row['max_chip_position'])], axis=1)\n","wt_enriched_windows_20['max_wt_chip_in_window'] = wt_enriched_windows_20.apply(lambda row: gapR_wt_norm.loc[int(row['max_chip_position'])], axis=1)\n","rif_enriched_windows_20['max_rif_chip_in_window'] = rif_enriched_windows_20.apply(lambda row: gapR_rif_norm.loc[int(row['max_chip_position'])], axis=1)\n","\n","wt_enriched_windows_5['rif_chip_at_position'] = wt_enriched_windows_5.apply(lambda row: gapR_rif_norm.loc[int(row['max_chip_position'])], axis=1)\n","rif_enriched_windows_5['wt_chip_at_position'] = rif_enriched_windows_5.apply(lambda row: gapR_wt_norm.loc[int(row['max_chip_position'])], axis=1)\n","wt_enriched_windows_20['rif_chip_at_position'] = wt_enriched_windows_20.apply(lambda row: gapR_rif_norm.loc[int(row['max_chip_position'])], axis=1)\n","rif_enriched_windows_20['wt_chip_at_position'] = rif_enriched_windows_20.apply(lambda row: gapR_wt_norm.loc[int(row['max_chip_position'])], axis=1)\n"]},{"cell_type":"markdown","metadata":{"id":"MTgiVRXlMfH1"},"source":["#Figure 9A: grouping untreated GapR-ChIP into AT-dependent and +SC-dependent"]},{"cell_type":"markdown","metadata":{"id":"5vIEcjKr1cjO"},"source":["calculate the difference in signals at the max chip peaks for WT and rif (used to calculate if the peak decreased more than 5% in response to rif treatment)"]},{"cell_type":"code","execution_count":18,"metadata":{"id":"uUu-tsWhUD46","executionInfo":{"status":"ok","timestamp":1775579377187,"user_tz":420,"elapsed":2,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"outputs":[],"source":["#calculate signal differencences\n","wt_enriched_windows_5['max_signal_difference'] = wt_enriched_windows_5['max_wt_chip_in_window'] - wt_enriched_windows_5['rif_chip_at_position']\n","wt_enriched_windows_20['max_signal_difference'] = wt_enriched_windows_20['max_wt_chip_in_window'] - wt_enriched_windows_20['rif_chip_at_position']\n","\n","# calculate the fraction of the change that difference is\n","wt_enriched_windows_5['max_signal_frac_change'] = wt_enriched_windows_5['max_signal_difference'] / wt_enriched_windows_5['max_wt_chip_in_window']\n","wt_enriched_windows_20['max_signal_frac_change'] = wt_enriched_windows_20['max_signal_difference'] / wt_enriched_windows_20['max_wt_chip_in_window']\n"]},{"cell_type":"code","execution_count":19,"metadata":{"id":"JKRmxG7oGi3s","executionInfo":{"status":"ok","timestamp":1775579377242,"user_tz":420,"elapsed":41,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"outputs":[],"source":["#assign SUPERCOILING INDEPENDENT peaks (max chip signal does not decrease in response to rif)\n","\n","def categorize_by_max_sign(df, threshold):\n","    group = []\n","    for _, row in df.iterrows():\n","        if row['max_signal_frac_change'] <= threshold: #this is the cutoff generated from top 5% change\n","            group.append('Group A')\n","        else:\n","            group.append('Group A/B')\n","    df['Group_by_max_sign'] = group\n","    return df\n","\n","#only run the function on wt enriched windows\n","wt_enriched_windows_5 = categorize_by_max_sign(wt_enriched_windows_5.copy(), 0.05 )\n","wt_enriched_windows_20 = categorize_by_max_sign(wt_enriched_windows_20.copy(), 0.05 )\n"]},{"cell_type":"markdown","metadata":{"id":"AzQH2A0WCJ1p"},"source":["Group A is the supercoil-independent peaks, group B is all supercoil sensitive peaks, but can still include AT-dependent supercoil dependent binding. Hence there are two dataframes"]},{"cell_type":"code","execution_count":20,"metadata":{"id":"1JuUPEloJRD_","executionInfo":{"status":"ok","timestamp":1775579377258,"user_tz":420,"elapsed":2,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"outputs":[],"source":["groupA_5_df = wt_enriched_windows_5[wt_enriched_windows_5['Group_by_max_sign'] == 'Group A'].copy()\n","groupAB_5_df = wt_enriched_windows_5[wt_enriched_windows_5['Group_by_max_sign'] == 'Group A/B'].copy()\n","\n","groupA_20_df = wt_enriched_windows_20[wt_enriched_windows_20['Group_by_max_sign'] == 'Group A'].copy()\n","groupAB_20_df = wt_enriched_windows_20[wt_enriched_windows_20['Group_by_max_sign'] == 'Group A/B'].copy()\n"]},{"cell_type":"markdown","metadata":{"id":"KXtH2f-zMllM"},"source":["Rif dataset has been shown to be AT-dependent in Figure 8, so the group B peaks that were shown to be supercoil-dependent (rif-sensitive) that are also in rif peak windows (AT-dependent) are considered BOTH AT/supercoil-dependent"]},{"cell_type":"code","execution_count":21,"metadata":{"id":"new_overlap_function","executionInfo":{"status":"ok","timestamp":1775579379226,"user_tz":420,"elapsed":1949,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}},"colab":{"base_uri":"https://localhost:8080/","height":459},"outputId":"c765c958-37f9-4a3d-ef17-1572fb569b1b"},"outputs":[{"output_type":"stream","name":"stdout","text":["number of Group A peaks: 107\n","number of Group A/B peaks: 585\n","number of Group B peaks: 311\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["#calculate if the peak form one class occurs in the window of another class:\n","def calculate_overlap_of_max_chip(df1, df2, max_chip_col_name, return_dataframe=False):\n","\n","    num_overlaps = 0\n","    num_non_overlaps = 0\n","    is_overlapping_list = []\n","\n","    #check overlaps between two dataframes. Easiest to use integers\n","    df2_starts = df2['start'].astype(int).values\n","    df2_ends = df2['end'].astype(int).values\n","\n","    for index, row in df1.iterrows():\n","        max_chip_pos = int(row[max_chip_col_name])\n","\n","        overlap_found = ((df2_starts <= max_chip_pos) & (max_chip_pos <= df2_ends)).any()  # creates a boolean Series. .any() checks if any value in this Series is True.\n","        is_overlapping_list.append(overlap_found)\n","\n","        if overlap_found:\n","            num_overlaps += 1\n","        else:\n","            num_non_overlaps += 1\n","\n","    if return_dataframe:\n","        df_out = df1.copy()\n","        df_out['is_overlapping'] = is_overlapping_list\n","        overlapping_df = df_out[df_out['is_overlapping']].drop(columns=['is_overlapping'])\n","        non_overlapping_df = df_out[~df_out['is_overlapping']].drop(columns=['is_overlapping'])\n","        return overlapping_df, non_overlapping_df\n","    else:\n","        return num_overlaps, num_non_overlaps\n","\n","#run calculate_overlap_of_max_chip on 5% and 20%\n","rif_overlapping_groupB_5_max_df, rif_non_overlapping_groupB_5_max_df = calculate_overlap_of_max_chip(groupAB_5_df, rif_enriched_windows_5, 'max_chip_position', return_dataframe=True)\n","rif_overlapping_groupB_20_max_df, rif_non_overlapping_groupB_20_max_df = calculate_overlap_of_max_chip(groupAB_20_df, rif_enriched_windows_20, 'max_chip_position', return_dataframe=True)\n","\n","# Assign group B and group BOTH reflecting on if there is an overlap in rif\n","groupBOTH_5_df = rif_overlapping_groupB_5_max_df\n","groupB_5_df = rif_non_overlapping_groupB_5_max_df\n","\n","groupBOTH_20_df = rif_overlapping_groupB_20_max_df\n","groupB_20_df = rif_non_overlapping_groupB_20_max_df\n","\n","#output the size of each froup for the venn diagram. using 5% for Fig 9A\n","print(\"number of Group A peaks:\" , len(groupA_5_df))\n","print(\"number of Group A/B peaks:\" , len(groupAB_5_df))\n","print (\"number of Group B peaks:\" , len(groupB_5_df))\n","\n","#build 9A venn diagram:\n","venn2(subsets = (311, 107, 274), set_labels = ('+SC-dep', 'AT-dep'))\n","plt.savefig('./Fig7A-venn.pdf')\n","plt.show()\n"]},{"cell_type":"markdown","metadata":{"id":"BS1zQIXrUpGV"},"source":["# Figure S3A-C: visualization of grouping"]},{"cell_type":"code","execution_count":22,"metadata":{"id":"QUbL9UZWn8Pv","executionInfo":{"status":"ok","timestamp":1775579393427,"user_tz":420,"elapsed":14200,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"outputs":[],"source":["# make local AT-content trace easier to plot\n","at_arr = np.asarray(sliding_300_caulo)\n","if at_arr.ndim == 2 and at_arr.shape[0] == 1:\n","    at_arr = at_arr[0]\n","\n","# add in chIP seq peaks\n","wt_arr  = np.asarray(gapR_wt_norm)\n","rif_arr = np.asarray(gapR_rif_norm)\n","\n","#load rna-seq peaks this time wild-type is exposed to the same amount of glucose used to deplete GapR\n","# GSM2690552 and GSM2690553\n","WTglu_RNArev_df = load_rnaseq_data('./data/D16-4810-1939G_align_out_norm_rv.wig') #WT grown in glu for 6 hours (guo 2018)\n","WTglu_RNAfor_df = load_rnaseq_data('./data/D16-4810-1939G_align_out_norm_fw.wig')\n","RDepglu_RNArev_df = load_rnaseq_data('./data/D16-4811-1939G_align_out_norm_rv.wig')#Rdep grown in glu for 6 hours (guo 2018)\n","RDepglu_RNAfor_df = load_rnaseq_data('./data/D16-4811-1939G_align_out_norm_fw.wig')\n","\n","# add in rna-seq peaks\n","WT_for  = np.asarray(W356_RNAfor_df['value'])#this is from GapR 3XFLAG\n","WT_rev  = np.asarray(W356_RNArev_df['value'])\n","\n","RDep_for = np.asarray(RDepglu_RNAfor_df['value'])#Rdep from no tagged GapR and glucose for 6 hours\n","RDep_rev = np.asarray(RDepglu_RN