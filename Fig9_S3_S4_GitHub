trand = np.nan\n","    min_distance = np.inf\n","\n","    if tes_strand == '+':\n","        # For '+' genes, TSS should smaller coordinate\n","        filtered_tss = tss_df[\n","            (tss_df['TSS location'] < tes_location) &\n","            (tss_df['strand'] == '+')\n","        ]\n","        if not filtered_tss.empty:\n","            distances = tes_location - filtered_tss['TSS location']\n","            min_dist_idx = distances.idxmin()\n","            min_distance = distances[min_dist_idx]\n","            closest_tss_location = filtered_tss.loc[min_dist_idx, 'TSS location']\n","            closest_tss_strand = filtered_tss.loc[min_dist_idx, 'strand']\n","\n","    elif tes_strand == '-':\n","        # For '-' genes, TSS should be downstream (larger coordinate)\n","        filtered_tss = tss_df[\n","            (tss_df['TSS location'] > tes_location) &\n","            (tss_df['strand'] == '-')\n","        ]\n","        if not filtered_tss.empty:\n","            distances = filtered_tss['TSS location'] - tes_location   # positive distances\n","            min_dist_idx = distances.idxmin()\n","            min_distance = distances[min_dist_idx]\n","            closest_tss_location = filtered_tss.loc[min_dist_idx, 'TSS location']\n","            closest_tss_strand = filtered_tss.loc[min_dist_idx, 'strand']\n","\n","    return closest_tss_location, closest_tss_strand, min_distance\n","\n","#run on relevant dfs\n","groupA_5_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupA_5_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","groupB_5_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupB_5_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","groupA_20_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupA_20_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","groupB_20_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupB_20_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","groupBOTH_5_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupBOTH_5_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","groupBOTH_20_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupBOTH_20_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","rif_enriched_windows_5[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (rif_enriched_windows_5.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","rif_enriched_windows_20[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (rif_enriched_windows_20.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","wt_enriched_windows_5[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (wt_enriched_windows_5.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","wt_enriched_windows_20[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (wt_enriched_windows_20.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","wt_nochip_windows_5[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (wt_nochip_windows_5.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","wt_nochip_windows_20[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (wt_nochip_windows_20.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","rif_nochip_windows_5[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (rif_nochip_windows_5.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","rif_nochip_windows_20[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (rif_nochip_windows_20.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"F-hUNA8rTMV_"},"outputs":[],"source":[]},{"cell_type":"markdown","metadata":{"id":"UUls9qTkTMzk"},"source":["##from TSS to TES"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"TC4KBMEVep5L"},"outputs":[],"source":["\n","def find_max_txn_change_in_TSS_to_TES_excluding_proximal(\n","    tss_location,\n","    tss_strand,\n","    tes_location,\n","    log2foldchange_forward,\n","    log2foldchange_reverse,\n","    exclude_proximal_bp=100,\n","    error_on_invalid_window=True\n","):\n","    \"\"\"\n","    Window definition (excluding promoter-proximal):\n","      + strand: [tss_location + exclude_proximal_bp, tes_location]\n","      - strand: [tes_location, tss_location - exclude_proximal_bp]\n","\n","    Summary (same logic as before):\n","      - avg = mean of log2FC values in window\n","      - median = median of log2FC values in window\n","      - \"max change\" = value with largest magnitude (abs), keeping sign\n","\n","    Returns:\n","      (max_change_position, max_change_value, avg_change_value, median_change_value)\n","    \"\"\"\n","\n","    max_change_position = np.nan\n","    max_change_value = np.nan\n","    avg_change_value = np.nan\n","    median_change_value = np.nan\n","\n","    # Guard against missing inputs\n","    if pd.isna(tss_location) or pd.isna(tes_location) or pd.isna(tss_strand):\n","        if error_on_invalid_window:\n","            raise ValueError(f\"Missing input(s): TSS={tss_location}, TES={tes_location}, strand={tss_strand}\")\n","        return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","    # Pick track + compute window\n","    if tss_strand == '+':\n","        start = tss_location + exclude_proximal_bp\n","        end = tes_location\n","        df = log2foldchange_forward\n","        val_col = 'log_2_fold_change_for'\n","\n","    elif tss_strand == '-':\n","        start = tes_location\n","        end = tss_location - exclude_proximal_bp\n","        df = log2foldchange_reverse\n","        val_col = 'log_2_fold_change_rev'\n","\n","    else:\n","        if error_on_invalid_window:\n","            raise ValueError(f\"Unexpected strand value: {tss_strand!r} (expected '+' or '-')\")\n","        return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","    # Validate window\n","    if end <= start:\n","        msg = (f\"Invalid TSS→TES window ({tss_strand} strand) after excluding {exclude_proximal_bp} bp: \"\n","               f\"TSS={tss_location}, TES={tes_location}. Computed [{start}, {end}] (empty/reversed).\")\n","        if error_on_invalid_window:\n","            raise ValueError(msg)\n","        return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","    # Slice window\n","    window_df = df[(df['position'] >= start) & (df['position'] <= end)]\n","    if window_df.empty:\n","        return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","    # Summaries\n","    vals = window_df[val_col]\n","    avg_change_value = vals.mean()\n","    median_change_value = vals.median()\n","\n","    # \"Maximum change\" = largest magnitude (abs), keep sign\n","    idx = vals.abs().idxmax()\n","    max_change_position = window_df.loc[idx, 'position']\n","    max_change_value = window_df.loc[idx, val_col]\n","\n","    return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","groupA_5_df[['max_txn_change_elongation_position','max_txn_change_elongation_value','avg_txn_change_elongation_value','median_txn_change_elongation_value']] = pd.DataFrame(groupA_5_df.apply(lambda row: find_max_txn_change_in_TSS_to_TES_excluding_proximal(row['closest_facing_tss_to_tes'],row['closest_facing_tss_to_tes_strand'],row['nearest_tsstop_location'],log2foldchange_forward,log2foldchange_reverse,exclude_proximal_bp=100,error_on_invalid_window=False),axis=1).tolist(), index=groupA_5_df.index)\n","groupB_5_df[['max_txn_change_elongation_position','max_txn_change_elongation_value','avg_txn_change_elongation_value','median_txn_change_elongation_value']] = pd.DataFrame(groupB_5_df.apply(lambda row: find_max_txn_change_in_TSS_to_TES_excluding_proximal(row['closest_facing_tss_to_tes'],row['closest_facing_tss_to_tes_strand'],row['nearest_tsstop_location'],log2foldchange_forward,log2foldchange_reverse,exclude_proximal_bp=100,error_on_invalid_window=False),axis=1).tolist(), index=groupB_5_df.index)\n","groupA_20_df[['max_txn_change_elongation_position','max_txn_change_elongation_value','avg_txn_change_elongation_valu