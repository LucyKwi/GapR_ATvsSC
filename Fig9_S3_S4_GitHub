f_5_df, \"WT nochip\": lambda: nearest_tss_wt_nochip_20_df},\n","    'top5% rif':  {\"rif ChIP\": lambda: nearest_tss_rif_5_df,  \"rif nochip\": lambda: nearest_tss_rif_nochip_5_df},\n","    'top20% rif': {\"rif ChIP\": lambda: nearest_tss_rif_20_df, \"rif nochip\": lambda: nearest_tss_rif_nochip_20_df},\n","\n","    # Assuming top1% and top50% are not explicitly requested here, but if needed, they can be added based on their corresponding dfs (e.g., top1_A_perc, wt_nochip_1A_df)\n","}\n","\n","# Assuming COLUMN_TO_PLOT and NUM_BINS are defined in the environment from previous cells.\n","# If not, they would need to be re-defined here, e.g.:\n","COLUMN_TO_PLOT = 0 # Example, adjust as needed\n","NUM_BINS = np.arange(-5,5,0.133)\n","NUM_BINS[0] = -10\n","NUM_BINS[-1] = 10\n","\n","from scipy.stats import mannwhitneyu # Import for MW test\n","\n","sns.set(style=\"white\")\n","\n","for group_key, group_data in groups_vs_WT_nochip.items():\n","    # Determine plot_labels and colors dynamically based on group_key\n","    current_plot_labels = []\n","    current_palette = []\n","\n","    if 'A' in group_key:\n","        current_plot_labels = [\"Group A\", \"Group B\"]\n","        current_palette = ['darkorange', 'green']\n","    elif 'wt' in group_key:\n","        current_plot_labels = [\"wt ChIP\", \"WT nochip\"]\n","        current_palette = ['purple', 'gray']\n","    elif 'rif' in group_key:\n","        current_plot_labels = [\"rif ChIP\", \"rif nochip\"]\n","        current_palette = ['green', 'gray']\n","    else:\n","        print(f\"Skipping {group_key}: unrecognized group type.\")\n","        continue\n","\n","    color_map = dict(zip(current_plot_labels, current_palette))\n","\n","    # Determine the x-axis label from the column name\n","    xlabel_text = str(COLUMN_TO_PLOT)\n","    first_df_found = False\n","    for lbl in current_plot_labels:\n","        if lbl in group_data:\n","            try:\n","                # Use a dummy call to resolve_series to get the column name\n","                s_temp, resolved_col_name = resolve_series(group_data[lbl](), COLUMN_TO_PLOT)\n","                xlabel_text = resolved_col_name\n","                first_df_found = True\n","                break\n","            except Exception:\n","                pass\n","    if not first_df_found:\n","        print(f\"Could not determine x-axis label for {group_key}. Using default '{xlabel_text}'.\")\n","\n","    fig, ax = plt.subplots(nrows=1, ncols=1, figsize=(10, 5)) # Single subplot per comparison\n","    fig.suptitle(f\"{group_key.replace('A%', ' A').replace('B%', ' B')} vs WT nochip Distributions ({xlabel_text})\", y=0.99, fontsize=16)\n","\n","    # Recompute global limits for the current comparison\n","    all_vals_current_group = []\n","    for lbl in current_plot_labels:\n","        if lbl in group_data:\n","            try:\n","                s, _ = resolve_series(group_data[lbl](), COLUMN_TO_PLOT)\n","                if len(s): all_vals_current_group.append(s.values)\n","            except Exception:\n","                pass\n","\n","    if not all_vals_current_group:\n","        print(f\"No numeric data found for {group_key} at selector {COLUMN_TO_PLOT!r}. Skipping plot.\")\n","        plt.close(fig) # Close empty figure\n","        continue\n","\n","    global_min = float(np.min([v.min() for v in all_vals_current_group]))\n","    global_max = float(np.max([v.max() for v in all_vals_current_group]))\n","\n","    panel_df_list = []\n","    data_for_mw = [] # To store data for MW test\n","\n","    for label in current_plot_labels:\n","        if label in group_data:\n","            try:\n","                df = group_data[label]()\n","                s, col_name = resolve_series(df, COLUMN_TO_PLOT)\n","                panel_df_list.append(pd.DataFrame({\"value\": s.values, \"Group\": label, \"Percentile\": group_key}))\n","                data_for_mw.append(s.values) # Collect data for MW test\n","            except (NameError, KeyError, IndexError, ValueError):\n","                continue\n","        else:\n","            pass\n","\n","    if not panel_df_list:\n","        ax.set_visible(False)\n","        plt.close(fig)\n","        continue\n","\n","    panel_df = pd.concat(panel_df_list, ignore_index=True)\n","\n","    # Perform MW test if two data series are available\n","    if len(data_for_mw) == 2:\n","        try:\n","            stat, p_value = mannwhitneyu(data_for_mw[0], data_for_mw[1])\n","            # Annotate plot with p-value\n","            ax.text(0.95, 0.95, f'MW p-value: {p_value:.3e}',\n","                    verticalalignment='top', horizontalalignment='right',\n","                    transform=ax.transAxes, color='black', fontsize=12)\n","        except ValueError as e:\n","            print(f\"Could not perform MW test for {group_key}: {e}\")\n","\n","    # Filled bars with black outline; legend per subplot\n","    sns.histplot(\n","        data=panel_df,\n","        x=\"value\",\n","        hue=\"Group\",\n","        hue_order=current_plot_labels,\n","        bins=NUM_BINS,\n","        stat=\"density\",\n","        common_bins=True,\n","        common_norm=False,\n","        palette=color_map,\n","        element=\"bars\",\n","        fill=True,\n","        alpha=0.5,\n","        edgecolor=\"black\",\n","        linewidth=1,\n","        multiple=\"layer\",\n","        ax=ax,\n","        legend=True\n","    )\n","\n","    ax.set_ylim(0, 1)\n","    ax.set_xlim(-5, 5)\n","    ax.set_title(f\"{group_key}\", loc=\"left\", fontsize=13)\n","    ax.set_xlabel(xlabel_text)   # give every subplot the same x-axis label\n","    ax.tick_params(axis='x', which='both', labelsize=10)\n","\n","    plt.tight_layout(h_pad=1.5)\n","\n","    # Save with a descriptive filename\n","    file_name_prefix = group_key.replace('%', 'percent').replace('A', '_GroupA_').replace('B', '_GroupB_')\n","    #plt.savefig(f'./FINAL_{file_name_prefix}maxchange_nearestTSS.pdf')\n","    plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"cWXo5iVzj8-C","executionInfo":{"status":"ok","timestamp":1775579993369,"user_tz":420,"elapsed":2351,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}},"outputId":"f4eaa581-a4b4-4b32-d72a-f592bc47d5be"},"execution_count":68,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["# Fig 9G: transcription of upstream TU"],"metadata":{"id":"uy5AjC8SeNrN"}},{"cell_type":"code","source":["def facing_TSS(tes_location, tes_strand, tss_df):\n","    \"\"\"\n","    Find the closest TSS that is:\n","      - on the same strand as TES\n","      - consistent with gene direction:\n","          '+' strand gene: TSS must be upstream of TES (TSS < TES)\n","          '-' strand gene: TSS must be downstream of TES (TSS > TES)\n","    Returns: (closest_tss_location, closest_tss_strand, min_distance)\n","    \"\"\"\n","\n","    # --- handle strand encoding if TES strand is 0/1 ---\n","    if tes_strand in [1, \"1\"]:\n","        tes_strand = '+'\n","    elif tes_strand in [0, \"0\"]:\n","        tes_strand = '-'\n","\n","    closest_tss_location = np.nan\n","    closest_tss_strand = np.nan\n","    min_distance = np.inf\n","\n","    if tes_strand == '+':\n","        # For '+' genes, TSS should smaller coordinate\n","        filtered_tss = tss_df[\n","            (tss_df['TSS location'] < tes_location) &\n","            (tss_df['strand'] == '+')\n","        ]\n","        if not filtered_tss.empty:\n","            distances = tes_location - filtered_tss['TSS location']\n","            min_dist_idx = distances.idxmin()\n","            min_distance = distances[min_dist_idx]\n","            closest_tss_location = filtered_tss.loc[min_dist_idx, 'TSS location']\n","            closest_tss_strand = filtered_tss.loc[min_dist_idx, 'strand']\n","\n","    elif tes_strand == '-':\n","        # For '-' genes, TSS should be downstream (larger coordinate)\n","        filtered_tss = tss_df[\n","            (tss_df['TSS location'] > tes_location) &\n","            (tss_df['strand'] == '-')\n","        ]\n","        if not filtered_tss.empty:\n","            distances = filtered_tss['TSS location'] - tes_location   # positive distances\n","            min_dist_idx = distances.idxmin()\n","            min_distance = distances[min_dist_idx]\n","            closest_tss_location = filtered_tss.loc[min_dist_idx, 'TSS location']\n","            closest_tss_strand = filtered_tss.loc[min_dist_idx, 'strand']\n","\n","    return closest_tss_location, closest_tss_strand, min_distance\n","\n","#run on relevant dfs\n","groupA_5_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupA_5_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","groupB_5_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupB_5_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","groupA_20_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupA_20_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","groupB_20_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupB_20_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","groupBOTH_5_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupBOTH_5_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","groupBOTH_20_df[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (groupBOTH_20_df.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","rif_enriched_windows_5[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (rif_enriched_windows_5.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","rif_enriched_windows_20[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (rif_enriched_windows_20.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","wt_enriched_windows_5[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (wt_enriched_windows_5.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","wt_enriched_windows_20[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (wt_enriched_windows_20.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","wt_nochip_windows_5[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (wt_nochip_windows_5.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","wt_nochip_windows_20[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (wt_nochip_windows_20.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","\n","rif_nochip_windows_5[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (rif_nochip_windows_5.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n","rif_nochip_windows_20[['closest_facing_tss_to_tes','closest_facing_tss_to_tes_strand','distance_to_closest_facing_tss_to_tes']] = (rif_nochip_windows_20.apply(lambda row: facing_TSS(row['nearest_tsstop_location'],row['nearest_tsstop_strand'],all_tss),axis=1,result_type='expand'))\n"],"metadata":{"id":"h9-_9pL0fJK-","executionInfo":{"status":"ok","timestamp":1775581228123,"user_tz":420,"elapsed":16047,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"execution_count":69,"outputs":[]},{"cell_type":"code","source":[],"metadata":{"id":"F-hUNA8rTMV_"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["##Figure 9G: elongation"],"metadata":{"id":"UUls9qTkTMzk"}},{"cell_type":"code","source":["\n","def find_max_txn_change_in_TSS_to_TES_excluding_proximal(\n","    tss_location,\n","    tss_strand,\n","    tes_location,\n","    log2foldchange_forward,\n","    log2foldchange_reverse,\n","    exclude_proximal_bp=100,\n","    error_on_invalid_window=True\n","):\n","    \"\"\"\n","    Window definition (excluding promoter-proximal):\n","      + strand: [tss_location + exclude_proximal_bp, tes_location]\n","      - strand: [tes_location, tss_location - exclude_proximal_bp]\n","\n","    Summary (same logic as before):\n","      - avg = mean of log2FC values in window\n","      - median = median of log2FC values in window\n","      - \"max change\" = value with largest magnitude (abs), keeping sign\n","\n","    Returns:\n","      (max_change_position, max_change_value, avg_change_value, median_change_value)\n","    \"\"\"\n","\n","    max_change_position = np.nan\n","    max_change_value = np.nan\n","    avg_change_value = np.nan\n","    median_change_value = np.nan\n","\n","    # Guard against missing inputs\n","    if pd.isna(tss_location) or pd.isna(tes_location) or pd.isna(tss_strand):\n","        if error_on_invalid_window:\n","            raise ValueError(f\"Missing input(s): TSS={tss_location}, TES={tes_location}, strand={tss_strand}\")\n","        return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","    # Pick track + compute window\n","    if tss_strand == '+':\n","        start = tss_location + exclude_proximal_bp\n","        end = tes_location\n","        df = log2foldchange_forward\n","        val_col = 'log_2_fold_change_for'\n","\n","    elif tss_strand == '-':\n","        start = tes_location\n","        end = tss_location - exclude_proximal_bp\n","        df = log2foldchange_reverse\n","        val_col = 'log_2_fold_change_rev'\n","\n","    else:\n","        if error_on_invalid_window:\n","            raise ValueError(f\"Unexpected strand value: {tss_strand!r} (expected '+' or '-')\")\n","        return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","    # Validate window\n","    if end <= start:\n","        msg = (f\"Invalid TSS→TES window ({tss_strand} strand) after excluding {exclude_proximal_bp} bp: \"\n","               f\"TSS={tss_location}, TES={tes_location}. Computed [{start}, {end}] (empty/reversed).\")\n","        if error_on_invalid_window:\n","            raise ValueError(msg)\n","        return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","    # Slice window\n","    window_df = df[(df['position'] >= start) & (df['position'] <= end)]\n","    if window_df.empty:\n","        return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","    # Summaries\n","    vals = window_df[val_col]\n","    avg_change_value = vals.mean()\n","    median_change_value = vals.median()\n","\n","    # \"Maximum change\" = largest magnitude (abs), keep sign\n","    idx = vals.abs().idxmax()\n","    max_change_position = window_df.loc[idx, 'position']\n","    max_change_value = window_df.loc[idx, val_col]\n","\n","    return max_change_position, max_change_value, avg_change_value, median_change_value\n","\n","groupA_5_df[['max_txn_change_elongation_position','max_txn_change_elongation_value','avg_txn_change_elongation_value','median_txn_change_elongation_value']] = pd.DataFrame(groupA_5_df.apply(lambda row: find_max_txn_change_in_TSS_to_TES_excluding_proximal(row['closest_facing_tss_to_tes'],row['closest_facing_tss_to_tes_strand'],row['nearest_tsstop_location'],log2foldchange_forward,log2foldchange_reverse,exclude_proximal_bp=100,error_on_invalid_window=False),axis=1).tolist(), index=groupA_5_df.index)\n","groupB_5_df[['max_txn_change_elongation_position','max_txn_change_elongation_value','avg_txn_change_elongation_value','median_txn_change_elongation_value']] = pd.DataFrame(groupB_5_df.apply(lambda row: find_max_txn_change_in_TSS_to_TES_excluding_proximal(row['closest_facing_tss_to_tes'],row['closest_facing_tss_to_tes_strand'],row['nearest_tsstop_location'],log2foldchange_forward,log2foldchange_reverse,exclude_proximal_bp=100,error_on_invalid_window=False),axis=1).tolist(), index=groupB_5_df.index)\n","groupA_20_df[['max_txn_change_elong