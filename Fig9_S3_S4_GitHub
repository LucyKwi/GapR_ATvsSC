ion', 'nearest_tss_top20_A_perc')\n","nearest_tss_top20_B_perc= remove_duplicates_from_df(nearest_tss_top20_B_perc, 'closest_tss_position', 'nearest_tss_top20_B_perc')\n","\n","nearest_tss_wt_5_df = remove_duplicates_from_df(nearest_tss_wt_5_df, 'closest_tss_position', \"nearest_tss_wt5\")\n","nearest_tss_rif_5_df = remove_duplicates_from_df(nearest_tss_rif_5_df, 'closest_tss_position', \"nearest_tss_rif5\")\n","nearest_tss_wt_20_df = remove_duplicates_from_df(nearest_tss_wt_20_df, 'closest_tss_position', \"nearest_tss_wt20\")\n","nearest_tss_rif_20_df = remove_duplicates_from_df(nearest_tss_rif_20_df, 'closest_tss_position', \"nearest_tss_rif20\")\n","\n","nearest_tss_wt_nochip_5_df = remove_duplicates_from_df(nearest_tss_wt_nochip_5_df, 'closest_tss_position', \"nearest_tss_wt_nochip_5_df\")\n","nearest_tss_rif_nochip_20_df = remove_duplicates_from_df(nearest_tss_rif_nochip_20_df, 'closest_tss_position', \"nearest_tss_rif_nochip_20_df\")\n","nearest_tss_wt_nochip_20_df = remove_duplicates_from_df(nearest_tss_wt_nochip_20_df, 'closest_tss_position', \"nearest_tss_wt_nochip_20_df\")\n","nearest_tss_rif_nochip_5_df = remove_duplicates_from_df(nearest_tss_rif_nochip_5_df, 'closest_tss_position', \"nearest_tss_rif_nochip_5_df\")"]},{"cell_type":"markdown","metadata":{"id":"Swse9SOf_ubW"},"source":["Since we are modeling that transcription start sites are near promoters, we also filter out TSS sites that are more than 500bp away from the GapR peak"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"XhOBwp0mhRmz"},"outputs":[],"source":["def filter_rows_by_tss_distance(df, distance_threshold):\n","    \"\"\"\n","    Removes rows from the DataFrame where the distance between the\n","    closest TSS position and the chip position (max or min) exceeds\n","    a threshold.\n","\n","    The function will use 'max_chip_position' if it exists.\n","    If not, it will fall back to 'min_chip_position'.\n","\n","    Args:\n","        df (pd.DataFrame): Input DataFrame containing:\n","            - 'closest_tss_position'\n","            - 'max_chip_position' or 'min_chip_position'\n","        distance_threshold (int or float): Maximum allowed distance\n","            between closest TSS and chip position.\n","\n","    Returns:\n","        pd.DataFrame: Filtered DataFrame with only rows within the threshold.\n","    \"\"\"\n","\n","    # Decide which chip position column to use\n","    if 'max_chip_position' in df.columns:\n","        chip_position_column = 'max_chip_position'\n","    elif 'min_chip_position' in df.columns:\n","        chip_position_column = 'min_chip_position'\n","    else:\n","        raise ValueError(\n","            \"DataFrame must contain either 'max_chip_position' or 'min_chip_position'.\"\n","        )\n","\n","    # Calculate distance between closest TSS and chosen chip position\n","    df['distance_between_chip_and_closest_tss'] = (\n","        df[chip_position_column] - df['closest_tss_position']\n","    ).abs()\n","\n","    # Keep only rows within the distance threshold\n","    filtered_df = df[\n","        df['distance_between_chip_and_closest_tss'] <= distance_threshold\n","    ].copy()\n","\n","    return filtered_df\n","\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"jNkqRkG4iEpE"},"outputs":[],"source":["#filter out long range sites: window is movable we chose 500bp\n","nearest_tss_top5_A_perc = filter_rows_by_tss_distance(nearest_tss_top5_A_perc, 500)\n","nearest_tss_top5_B_perc = filter_rows_by_tss_distance(nearest_tss_top5_B_perc, 500)\n","nearest_tss_top20_A_perc = filter_rows_by_tss_distance(nearest_tss_top20_A_perc, 500)\n","nearest_tss_top20_B_perc = filter_rows_by_tss_distance(nearest_tss_top20_B_perc, 500)\n","\n","nearest_tss_wt_5_df = filter_rows_by_tss_distance(nearest_tss_wt_5_df, 500)\n","nearest_tss_wt_20_df = filter_rows_by_tss_distance(nearest_tss_wt_20_df, 500)\n","nearest_tss_rif_5_df = filter_rows_by_tss_distance(nearest_tss_rif_5_df, 500)\n","nearest_tss_rif_