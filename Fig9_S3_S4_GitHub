metadata":{"id":"Swse9SOf_ubW"}},{"cell_type":"code","source":["def filter_rows_by_tss_distance(df, distance_threshold):\n","    \"\"\"\n","    Removes rows from the DataFrame where the distance between the\n","    closest TSS position and the chip position (max or min) exceeds\n","    a threshold.\n","\n","    The function will use 'max_chip_position' if it exists.\n","    If not, it will fall back to 'min_chip_position'.\n","\n","    Args:\n","        df (pd.DataFrame): Input DataFrame containing:\n","            - 'closest_tss_position'\n","            - 'max_chip_position' or 'min_chip_position'\n","        distance_threshold (int or float): Maximum allowed distance\n","            between closest TSS and chip position.\n","\n","    Returns:\n","        pd.DataFrame: Filtered DataFrame with only rows within the threshold.\n","    \"\"\"\n","\n","    # Decide which chip position column to use\n","    if 'max_chip_position' in df.columns:\n","        chip_position_column = 'max_chip_position'\n","    elif 'min_chip_position' in df.columns:\n","        chip_position_column = 'min_chip_position'\n","    else:\n","        raise ValueError(\n","            \"DataFrame must contain either 'max_chip_position' or 'min_chip_position'.\"\n","        )\n","\n","    # Calculate distance between closest TSS and chosen chip position\n","    df['distance_between_chip_and_closest_tss'] = (\n","        df[chip_position_column] - df['closest_tss_position']\n","    ).abs()\n","\n","    # Keep only rows within the distance threshold\n","    filtered_df = df[\n","        df['distance_between_chip_and_closest_tss'] <= distance_threshold\n","    ].copy()\n","\n","    return filtered_df\n","\n"],"metadata":{"id":"XhOBwp0mhRmz","executionInfo":{"status":"ok","timestamp":1775579991016,"user_tz":420,"elapsed":1,"user":{"displayName":"Lucy Monica Lucykwi@UW.Edu","userId":"07808848249608184277"}}},"execution_count":66,"outputs":[]},{"cell_type":"code","source":["#filter out long range sites: