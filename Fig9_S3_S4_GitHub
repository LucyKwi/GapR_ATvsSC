"cell_type":"code","execution_count":null,"metadata":{"id":"bp8B82I3yDGa"},"outputs":[],"source":["#@title make log2fold change array\n","#for quicker processing adding a small pseudocount to avoid 0s\n","\n","def build_log2foldchange_dataframes(WT_RNAfor_dataframe,\n","                                    WT_RNArev_dataframe,\n","                                    RDep_RNAfor_dataframe,\n","                                    RDep_RNArev_dataframe,\n","                                    pseudocount=0.01):\n","    \"\"\"\n","    Builds two genome-wide log2 fold change dataframes:\n","      1) log2foldchange_forward: position + log_2_fold_change_for\n","      2) log2foldchange_reverse: position + log_2_fold_change_rev\n","\n","    Assumes each RNA dataframe has exactly:\n","      - 'position'\n","      - 'value'\n","\n","    This function will raise an error if WT and RDep do not have matching positions.\n","    \"\"\"\n","\n","    # Forward strand log2FC\n","    forward_merged_data = pd.merge(\n","        WT_RNAfor_dataframe,\n","        RDep_RNAfor_dataframe,\n","        on='position',\n","        how='inner',\n","        suffixes=('_WT', '_RDep')\n","    )\n","\n","    if len(forward_merged_data) != len(WT_RNAfor_dataframe) or len(forward_merged_data) != len(RDep_RNAfor_dataframe):\n","        raise ValueError(\n","            \"Forward strand WT and RDep RNA-seq tracks do not have matching positions. \"\n","            \"Please regenerate or re-check the input RNA-seq dataframes.\"\n","        )\n","\n","    forward_merged_data['log_2_fold_change_for'] = np.log2(\n","        (forward_merged_data['value_RDep'] + pseudocount) /\n","        (forward_merged_data['value_WT'] + pseudocount)\n","    )\n","\n","    log2foldchange_forward = forward_merged_data[\n","        ['position', 'log_2_fold_change_for']\n","    ].sort_values('position').reset_index(drop=True)\n","\n","\n","    # Reverse strand log2FC dataset\n","    reverse_merged_data = pd.merge(\n","        WT_RNArev_dataframe,\n","        RDep_RNArev_dataframe,\n","        on='position',\n","        how='inner',\n","        suffixes=('_WT', '_RDep')\n","    )\n","\n","    if len(reverse_merged_data) != len(WT_RNArev_dataframe) or len(reverse_merged_data) != len(RDep_RNArev_dataframe):\n","        raise ValueError(\n","            \"Reverse strand WT and RDep RNA-seq tracks do not have matching positions. \"\n","            \"Please regenerate or re-check the input RNA-seq dataframes.\"\n","        )\n","\n","    reverse_merged_data['log_2_fold_change_rev'] = np.log2(\n","        (reverse_merged_data['value_RDep'] + pseudocount) /\n","        (reverse_merged_data['value_WT'] + pseudocount)\n","    )\n","\n","    log2foldchange_reverse = reverse_merged_data[\n","        ['position', 'log_2_fold_change_rev']\n","    ].sort_values('position').reset_index(drop=True)\n","\n","    return log2foldchange_forward, log2foldchange_reverse\n","\n","\n","log2foldchange_forward, log2foldchange_reverse = build_log2foldchange_dataframes(\n","    WT_RNAfor_dataframe=WTglu_RNAfor_df,\n","    WT_RNArev_dataframe=WTglu_RNArev_df,\n","    RDep_RNAfor_dataframe=RDepglu_RNAfor_df,\n","    RDep_RNArev_dataframe=RDepglu_RNArev_df,\n","    pseudocount=0.01\n",")"]},{"cell_type":"markdown","metadata":{"id":"s5wybgIY7I7w"},"source":["The next couple functions are all made to build a large pandas dataframe with all relevant information. It will ID the upstream transcription start site, the downstream txn start site, which one is closer, and the log2fold change in the strand conscious 500bp range at all these positions"]},{"cell_type":"markdown","metadata":{"id":"wHJt5cXuAx9y"},"source":["#Figure 9E, S4D: nearest TSS"]},{"cell_type":"markdown","metadata":{"id":"FmalxPEc_AQo"},"source":[" I am re-loading the dfs from Step1 before each analysis."]},{"cell_type":"code","execution_count":null,"metadata":{"id":"0lMulO8p_GjN"},"outputs":[],"source":["# rename dataframes so I can sort them and not lose data\n