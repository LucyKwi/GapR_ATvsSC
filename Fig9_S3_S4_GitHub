taFrame): DataFrame with log2FC for reverse strand.\n","        window_half_size (int): Half the size of the window (e.g., 500 for a 1000bp window).\n","\n","    Returns:\n","        tuple: (max_change_position, max_change_value, avg_change_value, median_change_value)\n","               Returns (np.nan, np.nan, np.nan, np.nan) if no valid data in window or invalid input.\n","    \"\"\"\n","    # Determine which chip position column to use\n","    chip_position = np.nan\n","    if 'max_chip_position' in row.index:\n","        chip_position = row['max_chip_position']\n","    elif 'min_chip_position' in row.index:\n","        chip_position = row['min_chip_position']\n","    else:\n","        return np.nan, np.nan, np.nan, np.nan # No valid chip position found\n","\n","    # Initialize results\n","    best_max_change_position = np.nan\n","    best_max_change_value = np.nan\n","    best_avg_change_value = np.nan # These can remain nan if no data is found\n","    best_median_change_value = np.nan # These can remain nan if no data is found\n","    max_absolute_change = -1 # To track the largest absolute change found\n","\n","    if pd.isna(chip_position):\n","        return np.nan, np.nan, np.nan, np.nan\n","\n","    start_coord = int(chip_position - window_half_size)\n","    end_coord = int(chip_position + window_half_size)\n","\n","    # Ensure coordinates are non-negative\n","    start_coord = max(0, start_coord)\n","\n","    results_list = [] # Store results for both strands\n","\n","    for df_l2fc, col_name in [(log2foldchange_forward, 'log_2_fold_change_for'),\n","                             (log2foldchange_reverse, 'log_2_fold_change_rev')]:\n","\n","        window_data = df_l2fc[\n","            (df_l2fc['position'] >= start_coord) &\n","            (df_l2fc['position'] <= end_coord)\n","        ]\n","\n","        if not window_data.empty:\n","            vals = window_data[col_name].dropna()\n","\n","            if not vals.empty:\n","                current_avg = vals.mean()\n","                current_median = vals.median()\n","\n","                idx_max_magnitude = vals.abs().idxmax()\n","                current_max_pos = window_data.loc[idx_max_magnitude, 'position']\n","                current_max_val = vals.loc[idx_max_magnitude]\n","                current_abs_max = np.abs(current_max_val)\n","\n","                results_list.append({\n","                    'abs_max': current_abs_max,\n","                    'position': current_max_pos,\n","                    'value': current_max_val,\n","                    'avg': current_avg,\n","                    'median': current_median\n","                })\n","\n","    if results_list:\n","        # Find the entry with the highest absolute max change\n","        best_result = max(results_list, key=lambda x: x['abs_max'])\n","        return best_result['position'], best_result['value'], best_result['avg'], best_result['median']\n","    else:\n","        return np.nan, np.nan, np.nan, np.nan # No data found in window for either strand"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"VL2becH-Tjbf"},"outputs":[],"source":["groupA_5_df[['max_txn_change_chip_window_position','max_txn_change_chip_window_value','avg_txn_change_chip_window_value','median_txn_change_chip_window_value']] = groupA_5_df.apply(lambda row: find_max_txn_change_in_chip_window(row, log2foldchange_forward, log2foldchange_reverse), axis=1, result_type='expand')\n","groupB_5_df[['max_txn_change_chip_window_position','max_txn_change_chip_window_value','avg_txn_change_chip_window_value','median_txn_change_chip_window_value']] = groupB_5_df.apply(lambda row: find_max_txn_change_in_chip_window(row, log2foldchange_forward, log2foldchange_reverse), axis=1, result_type='expand')\n","groupBOTH_5_df[['max_txn_change_chip_window_position','max_txn_change_chip_window_value','avg_txn_change_chip_window_value','median_txn_change_chip_window_value']] = groupBOTH_5_df.apply(lambda row: find_max_txn_change_