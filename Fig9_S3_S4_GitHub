},"outputs":[],"source":["# ensure resolve_series exists\n","try:\n","    resolve_series\n","except NameError:\n","    import pandas as pd\n","    def resolve_series(df: pd.DataFrame, selector):\n","        if df is None or df.empty:\n","            raise ValueError(\"Empty DataFrame.\")\n","        if isinstance(selector, int):\n","            col_name = df.columns[selector]\n","        else:\n","            col_name = selector\n","            if col_name not in df.columns:\n","                raise KeyError(f\"Column {col_name!r} not found.\")\n","        s = pd.to_numeric(df[col_name], errors=\"coerce\").dropna()\n","        if s.empty:\n","            raise ValueError(f\"Column {col_name!r} has no numeric values after coercion.\")\n","        return s, col_name\n"]},{"cell_type":"markdown","metadata":{"id":"NByXXy4U9cKB"},"source":["now I am going to clean up nearest tss using two actions. First, I remove TSS's that may be under influece of both AT/+SC. I use find_common_tss to remove TSS sites where an AT-only or +SC-only grpup is calling a TSS that is shared by the both AT/SC group. Second, I use remove_common_tss_rows to remove any additional time one TSS is called by multipule peaks."]},{"cell_type":"code","execution_count":null,"metadata":{"id":"01jZRSOFS1Y6"},"outputs":[],"source":["def find_common_tss(df_A, df_B, df_name, tss_column='nearest_tss_location'):\n","\n","    df_name = df_name\n","    tss_A = set(df_A[tss_column])\n","    tss_B = set(df_B[tss_column])\n","\n","    # Find the intersection (common TSS locations)\n","    common_tss = tss_A.intersection(tss_B)\n","\n","    # Filter both DataFrames to include only rows with common TSS locations\n","    df_A_common = df_A[df_A[tss_column].isin(common_tss)]\n","    df_B_common = df_B[df_B[tss_column].isin(common_tss)]\n","\n","    # Concatenate the filtered DataFrames into tss_in_AB\n","    tss_in_AB = pd.concat([df_A_common, df_B_common], ignore_index=True)\n","\n","    # calculate percent of df that was removed\n","    tssA_percent = (len(df_A_common)) / len(df_A) * 100\n","    tssB_percent = (len(df_B_common)) / len(df_B) * 100\n","\n","    #print(f\"{len(tss_in_AB)} common TSS locations found in {df_name}. ({tssA_percent}% of A) and ({tssB_percent}% of B) \")\n","    return tss_in_AB\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"pB2ot3RMS1Y7"},"outputs":[],"source":["# use find_common_tss to remove duplicates\n","tss_in_AB_top5_perc = find_common_tss(nearest_tss_top5_A_perc, nearest_tss_top5_B_perc, 'top5% AB', 'closest_tss_position')\n","tss_in_AB_top20_perc = find_common_tss(nearest_tss_top20_A_perc, nearest_tss_top20_B_perc, 'top20% AB', 'closest_tss_position')\n","\n","tss_in_wt5_top5_perc = find_common_tss(nearest_tss_wt_5_df, nearest_tss_wt_nochip_5_df, 'top5% wt', 'closest_tss_position')\n","tss_in_wt20_top20_perc = find_common_tss(nearest_tss_wt_20_df, nearest_tss_wt_nochip_20_df, 'top20% wt', 'closest_tss_position')\n","tss_in_rif5_top5_perc = find_common_tss(nearest_tss_rif_5_df, nearest_tss_rif_nochip_5_df, 'top5% rif', 'closest_tss_position')\n","tss_in_rif20_top20_perc = find_common_tss(nearest_tss_rif_20_df, nearest_tss_rif_nochip_20_df, 'top20% rif', 'closest_tss_position')\n","\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"CBBVB_AOX_wN"},"outputs":[],"source":["def remove_common_tss_rows(df_A, df_B, common_tss_df, tss_column='closest_tss_position'):\n","\n","    common_tss_locations = set(common_tss_df[tss_column].unique())\n","\n","    original_len_A = len(df_A)\n","    original_len_B = len(df_B)\n","\n","    df_A_cleaned = df_A[~df_A[tss_column].isin(common_tss_locations)].copy()\n","    df_B_cleaned = df_B[~df_B[tss_column].isin(common_tss_locations)].copy()\n","\n","    removed_A = original_len_A - len(df_A_cleaned)\n","    removed_B = original_len_B - len(df_B_cleaned)\n","\n","    #print(f\"Removed {removed_A} rows from df_A (original length: {original_len_A}, new length: {len(df_A_cleaned)}).\")\