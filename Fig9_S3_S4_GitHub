at selector {COLUMN_TO_PLOT!r}. Skipping plot.\")\n","        plt.close(fig) # Close empty figure\n","        continue\n","\n","    global_min = float(np.min([v.min() for v in all_vals_current_group]))\n","    global_max = float(np.max([v.max() for v in all_vals_current_group]))\n","\n","    panel_df_list = []\n","    data_for_mw = [] # To store data for MW test\n","\n","    for label in current_plot_labels:\n","        if label in group_data:\n","            try:\n","                df = group_data[label]()\n","                s, col_name = resolve_series(df, COLUMN_TO_PLOT)\n","                panel_df_list.append(pd.DataFrame({\"value\": s.values, \"Group\": label, \"Percentile\": group_key}))\n","                data_for_mw.append(s.values) # Collect data for MW test\n","            except (NameError, KeyError, IndexError, ValueError):\n","                continue\n","        else:\n","            pass\n","\n","    if not panel_df_list:\n","        ax.set_visible(False)\n","        plt.close(fig)\n","        continue\n","\n","    panel_df = pd.concat(panel_df_list, ignore_index=True)\n","\n","    # Perform MW test if two data series are available\n","    if len(data_for_mw) == 2:\n","        try:\n","            stat, p_value = mannwhitneyu(data_for_mw[0], data_for_mw[1])\n","            # Annotate plot with p-value\n","            ax.text(0.95, 0.95, f'MW p-value: {p_value:.3e}',\n","                    verticalalignment='top', horizontalalignment='right',\n","                    transform=ax.transAxes, color='black', fontsize=12)\n","        except ValueError as e:\n","            print(f\"Could not perform MW test for {group_key}: {e}\")\n","\n","    # Filled bars with black outline; legend per subplot\n","    sns.histplot(\n","        data=panel_df,\n","        x=\"value\",\n","        hue=\"Group\",\n","        hue_order=current_plot_labels,\n","        bins=NUM_BINS,\n","        stat=\"density\",\n","        common_bins=True,\n","        common_norm=False,